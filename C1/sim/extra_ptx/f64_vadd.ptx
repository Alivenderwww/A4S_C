.version 7.0
.target sm_70
.address_size 64

// FP64 vector add - exercises 64-bit register-pair values (f64 load/add/store)
// so the pair-aware register allocator is tested (esp. under register pressure).
.visible .entry vadd_f64(
    .param .u64 param_a,
    .param .u64 param_b,
    .param .u64 param_c,
    .param .u32 param_n
)
{
    .reg .pred %p<2>;
    .reg .b32  %r<6>;
    .reg .b64  %rd<10>;
    .reg .f64  %fd<4>;

    ld.param.u64 %rd1, [param_a];
    ld.param.u64 %rd2, [param_b];
    ld.param.u64 %rd3, [param_c];
    ld.param.u32 %r1,  [param_n];

    mov.u32 %r2, %tid.x;
    mov.u32 %r3, %ctaid.x;
    mov.u32 %r4, %ntid.x;
    mad.lo.u32 %r5, %r3, %r4, %r2;

    setp.ge.u32 %p1, %r5, %r1;
    @%p1 bra DONE;

    mul.wide.u32 %rd4, %r5, 8;      // fp64 element = 8 bytes
    add.u64 %rd5, %rd1, %rd4;
    add.u64 %rd6, %rd2, %rd4;
    add.u64 %rd7, %rd3, %rd4;

    ld.global.f64 %fd1, [%rd5];
    ld.global.f64 %fd2, [%rd6];
    add.f64 %fd3, %fd1, %fd2;
    st.global.f64 [%rd7], %fd3;

DONE:
    ret;
}
